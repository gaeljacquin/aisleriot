{
  "name": "aisleriot",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "add:web": "pnpm --filter ./apps/web add",
    "add:ui": "pnpm --filter ./packages/ui add"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
