{
  "name": "aisleriot",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint --filter '!@workspace/ui'",
    "lint:web": "turbo lint --filter @workspace/web",
    "test": "turbo test",
    "test:web": "turbo test --filter @workspace/web",
    "format": "turbo format",
    "format:write": "turbo format -- --write",
    "typecheck": "turbo typecheck",
    "add:web": "pnpm --filter ./apps/web add",
    "add:ui": "pnpm --filter ./packages/ui add"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.8",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
